<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.client.controller.CreateAuctionController">

    <VBox alignment="TOP_CENTER" maxHeight="600.0" maxWidth="500.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">

        <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
        </padding>

        <VBox alignment="CENTER" spacing="5">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="not enough Auction Creation" />
        </VBox>

        <Label fx:id="errorLabel" textFill="RED" wrapText="true" />

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Item Name" />
            <TextField fx:id="nameField" promptText="Enter name" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 4;" />
        </VBox>

        <HBox spacing="15.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Category" />
                <ComboBox fx:id="typeComboBox" maxWidth="Infinity" promptText="Select Type" style="-fx-padding: 5; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 4;">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Electronics" />
                            <String fx:value="Art" />
                            <String fx:value="Vehicle" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Duration (Milliseconds)" />
                <TextField fx:id="durationField" promptText="e.g., 24" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 4;" />
            </VBox>
        </HBox>

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Starting Price ($)" />
            <TextField fx:id="startingPriceField" promptText="0.00" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 4;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Description" />
            <TextArea fx:id="descField" prefHeight="100.0" promptText="Describe pls..." style="-fx-padding: 5; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 4;" wrapText="true" />
        </VBox>

        <VBox fx:id="dynamicAttributesContainer" spacing="10.0" style="-fx-padding: 10; -fx-border-color: #ecf0f1; -fx-border-radius: 4; -fx-border-width: 1;">
            <Label text="Select a category to see specific attributes." style="-fx-text-fill: #95a5a6; -fx-font-style: italic;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS" /> <HBox alignment="CENTER" spacing="15.0">
        <Button onAction="#handleCancel" prefWidth="150" style="-fx-background-color: #ecf0f1; -fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-padding: 12px; -fx-background-radius: 4; -fx-cursor: hand;" text="Cancel" />

        <Button onAction="#handleSubmit" prefWidth="250" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px; -fx-background-radius: 4; -fx-cursor: hand;" text="Create" />
    </HBox>
    </VBox>
</StackPane>

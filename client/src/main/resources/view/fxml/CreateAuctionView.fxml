<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="root-pane" stylesheets="@../css/global.css, @../css/create-auction.css"
           fx:controller="com.app.client.controller.CreateAuctionController">

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0;">

        <VBox alignment="TOP_CENTER">
            <padding>
                <Insets top="40.0" bottom="40.0" />
            </padding>

            <VBox alignment="TOP_CENTER" maxWidth="500.0" spacing="15.0" styleClass="form-card">

                <padding>
                    <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                </padding>

                <VBox alignment="CENTER" spacing="5">
                    <Label styleClass="form-title" text="Auction Creation" />
                </VBox>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" />

                <VBox spacing="5.0">
                    <Label styleClass="input-label" text="Item Name" />
                    <TextField fx:id="nameField" promptText="Enter name" styleClass="form-input" />
                </VBox>

                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="input-label" text="Category" />
                        <ComboBox fx:id="typeComboBox" maxWidth="Infinity" promptText="Select Type" styleClass="form-combo">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Electronics" />
                                    <String fx:value="Art" />
                                    <String fx:value="Vehicle" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>

                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="input-label" text="Duration (Milliseconds)" />
                        <TextField fx:id="durationField" promptText="e.g., 24" styleClass="form-input" />
                    </VBox>
                </HBox>

                <VBox spacing="5.0">
                    <Label styleClass="input-label" text="Start Delay (Seconds)" />
                    <TextField fx:id="startDelayMinutesField" promptText="blank = start immediately" styleClass="form-input" />
                </VBox>

                <VBox spacing="5.0">
                    <Label styleClass="input-label" text="Starting Price ($)" />
                    <TextField fx:id="startingPriceField" promptText="0.00" styleClass="form-input" />
                </VBox>

                <VBox spacing="5.0">
                    <Label styleClass="input-label" text="Description" />
                    <TextArea fx:id="descField" prefHeight="100.0" promptText="Describe pls..." styleClass="form-area" wrapText="true" />
                </VBox>

                <VBox fx:id="dynamicAttributesContainer" spacing="10.0" styleClass="dynamic-container">
                    <Label styleClass="dynamic-info-label" text="Select a category to see specific attributes."/>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="15.0">
                    <Button onAction="#handleCancel" prefWidth="150" styleClass="cancel-btn" text="Cancel" />
                    <Button onAction="#handleSubmit" prefWidth="250" styleClass="submit-btn" text="Create" />
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
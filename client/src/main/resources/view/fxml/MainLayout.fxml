<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" styleClass="root-pane" stylesheets="@../css/global.css, @../css/mainlayout.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.client.controller.MainLayoutController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
            <padding>
                <Insets bottom="15" left="30" right="35" top="15" />
            </padding>

            <Label styleClass="brand-title" text="tGhauctionRM" />

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="welcomeLabel" styleClass="user-name" text="User Name" />
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label fx:id="roleLabel" styleClass="user-role" text="BIDDER" />
                    <Label fx:id="balanceLabel" styleClass="user-balance" text="Balance: $0.00" />
                </HBox>
            </VBox>

            <Region prefWidth="10" />
            <Button onAction="#handleLogout" styleClass="action-btn, logout-btn" text="Logout" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="180.0" spacing="10.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="0.0" right="0.0" top="0.0" />
            </padding>

<!--            <Label styleClass="sidebar-title" text="MAIN MENU" />-->
            <Region prefHeight="10.0" />

            <Button fx:id="dashboardBtn" maxWidth="Infinity" onAction="#navToDashboard" styleClass="sidebar-btn" text="Live Auctions" />

            <Button fx:id="myListingsBtn" managed="false" maxWidth="Infinity" onAction="#navToMyListings" styleClass="sidebar-btn" text="My Listings" visible="false" />
            <Button fx:id="winningBidsBtn" managed="false" maxWidth="Infinity" onAction="#navToWinningBids" styleClass="sidebar-btn" text="Winning Bids" visible="false" />

            <Button fx:id="createAuctionBtn" maxWidth="Infinity" onAction="#navToCreate" prefWidth="181.0" styleClass="sidebar-btn, cta-btn" text="Create Auction" />

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f4f6f8;" />
    </center>

</BorderPane>

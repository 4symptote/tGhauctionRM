<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.client.controller.RegisterController">

    <VBox alignment="CENTER" maxHeight="550.0" maxWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <Label text="not enough RegisterView">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <Label fx:id="errorLabel" textFill="RED" wrapText="true" />

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Username" />
            <TextField fx:id="usernameField" promptText="Choose a username..." style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-background-color: #f8f9fa;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Email" />
            <TextField fx:id="emailField" promptText="Enter your email..." style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-background-color: #f8f9fa;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Password" />
            <PasswordField fx:id="passwordField" promptText="Create a password..." style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-background-color: #f8f9fa;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Account Role" />
            <ComboBox fx:id="roleComboBox" prefWidth="Infinity" promptText="Role..." style="-fx-padding: 5; -fx-background-radius: 4; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-background-color: #f8f9fa;">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="BIDDER" />
                        <String fx:value="SELLER" />
                    </FXCollections>
                </items>
            </ComboBox>
        </VBox>

        <Region prefHeight="10" />

        <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" prefWidth="Infinity" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px; -fx-background-radius: 4; -fx-cursor: hand;" text="Register" />

        <Hyperlink onAction="#switchToLogin" style="-fx-text-fill: #7f8c8d;" text="Back to login" />
    </VBox>
</StackPane>

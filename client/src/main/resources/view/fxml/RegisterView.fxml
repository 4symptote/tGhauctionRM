<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="12.0" prefHeight="500.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.client.controller.RegisterController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Create Account">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label fx:id="errorLabel" textFill="RED" wrapText="true" />

    <VBox spacing="5.0">
        <Label text="Username" />
        <TextField fx:id="usernameField" promptText="Choose a username..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Email" />
        <TextField fx:id="emailField" promptText="Enter your email..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Password" />
        <PasswordField fx:id="passwordField" promptText="Create a password..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Account Role" />
        <ComboBox fx:id="roleComboBox" prefWidth="Infinity" promptText="Role...">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="BIDDER" />
                    <String fx:value="SELLER" />
                </FXCollections>
            </items>
        </ComboBox>
    </VBox>

    <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" prefWidth="Infinity" text="Register" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px;" />

    <Hyperlink onAction="#switchToLogin" text="back to login" />
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane stylesheets="@auction_dashboard.css" styleClass="root-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT">
            <StackPane styleClass="logo-container">
                <SVGPath content="M12 2L2 12l10 10 10-10L12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5z" styleClass="logo-icon"/>
            </StackPane>
            <VBox alignment="CENTER_LEFT" spacing="2">
                <Label text="Grand Auction House" styleClass="header-title"/>
                <Label text="EST. 1892 • TRAVELERS' EXCHANGE" styleClass="header-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="15">
                <HBox styleClass="search-box" alignment="CENTER_LEFT">
                    <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" styleClass="search-icon"/>
                    <TextField promptText="Search expeditions..." styleClass="search-input"/>
                </HBox>
                <Button styleClass="icon-button">
                    <graphic>
                        <SVGPath content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/>
                    </graphic>
                </Button>
                <Button text="EXPLORER" styleClass="profile-button">
                    <graphic>
                        <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </graphic>
                </Button>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" spacing="25">
            <VBox styleClass="nav-guide-box" alignment="CENTER">
                <SVGPath content="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z" styleClass="nav-guide-icon"/>
                <Label text="NAVIGATION" styleClass="nav-guide-title"/>
                <Label text="Explorer's Guide" styleClass="nav-guide-subtitle"/>
            </VBox>

            <VBox styleClass="nav-menu">
                <Button text="Main Hall" styleClass="nav-item, nav-item-active"/>
                <Button text="Active Bidding" styleClass="nav-item"/>
                <Button text="Past Expeditions" styleClass="nav-item"/>
                <Button text="My Collection" styleClass="nav-item"/>
                <Button text="Acquisitions" styleClass="nav-item"/>
                <Button text="Market Trends" styleClass="nav-item"/>
                <Button text="Preferences" styleClass="nav-item"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox styleClass="status-box">
                <Label text="TRADING POST STATUS" styleClass="status-title"/>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Region styleClass="status-indicator"/>
                    <Label text="Open for Business" styleClass="status-text"/>
                </HBox>
                <Label text="1,247 Travelers Online" styleClass="status-subtext"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <VBox styleClass="main-content" spacing="35">

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Region styleClass="title-ribbon"/>
                    <VBox spacing="3">
                        <Label text="Main Trading Hall" styleClass="page-title"/>
                        <Label text="Where adventurers meet antiquity • Est. 1892" styleClass="page-subtitle"/>
                    </VBox>
                </HBox>

                <HBox spacing="20">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <HBox alignment="TOP_LEFT" spacing="12">
                            <SVGPath content="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-2.71-3.7V3h-4v2.21c-1.83.42-3.15 1.83-3.15 3.59 0 2.45 2.06 3.2 4.5 3.84 2.53.67 3.3 1.55 3.3 2.76 0 1.14-1.01 2-2.8 2-1.99 0-3-.95-3.13-2.16H6.18c.15 2.21 1.55 3.61 3.22 4.04V21h4v-2.24c1.86-.44 3.2-1.92 3.2-3.76 0-2.61-2.2-3.37-4.8-4.1z" styleClass="stat-icon"/>
                            <VBox spacing="2">
                                <Label text="MARKET" styleClass="stat-label"/>
                                <Label text="VALUE" styleClass="stat-label"/>
                                <Label text="Current expedition listings" styleClass="stat-sublabel"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="↑12.5%" styleClass="stat-badge"/>
                        </HBox>
                        <Label text="\$48,520" styleClass="stat-value"/>
                        <Region styleClass="stat-divider"/>
                    </VBox>

                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <HBox alignment="TOP_LEFT" spacing="12">
                            <SVGPath content="M21.6 11.22L17 6.64l-1.42 1.41 1.03 1.04-8.84 8.84c-.39.39-.39 1.02 0 1.41l2.83 2.83c.39.39 1.02.39 1.41 0l8.84-8.84 1.03 1.04 1.42-1.41-1.7-1.74zm-9.54 9.54l-2.83-2.83 8.13-8.13 2.83 2.83-8.13 8.13zM6.64 12.64l4.24-4.24-1.41-1.42-4.24 4.25z" styleClass="stat-icon"/>
                            <VBox spacing="2">
                                <Label text="ACTIVE" styleClass="stat-label"/>
                                <Label text="OFFERS" styleClass="stat-label"/>
                                <Label text="Pending negotiations" styleClass="stat-sublabel"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="↑8.3%" styleClass="stat-badge"/>
                        </HBox>
                        <Label text="127" styleClass="stat-value"/>
                        <Region styleClass="stat-divider"/>
                    </VBox>

                </HBox>

                <StackPane alignment="TOP_CENTER">
                    <VBox styleClass="catalog-container">

                        <HBox alignment="CENTER_LEFT" styleClass="catalog-header-area">
                            <Label text="Discover rare treasures from distant lands" styleClass="catalog-desc"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="6 AVAILABLE" styleClass="available-btn"/>
                        </HBox>

                        <FlowPane hgap="25" vgap="25" styleClass="catalog-grid">

                            <AnchorPane styleClass="item-card">
                                <VBox spacing="12" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">
                                    <Label text="Victorian Pocket Watch" styleClass="item-title"/>
                                    <Region styleClass="item-divider"/>
                                    <VBox styleClass="bid-box">
                                        <Label text="CURRENT BID" styleClass="bid-label"/>
                                        <Label text="\$2,500" styleClass="bid-value"/>
                                    </VBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="2h 15m" styleClass="item-time"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="24 BIDS PLACED" styleClass="item-bids"/>
                                    </HBox>
                                    <Button text="PLACE BID" styleClass="place-bid-btn" maxWidth="Infinity"/>
                                </VBox>
                                <Label text="OPEN" styleClass="stamp, stamp-open" AnchorPane.topAnchor="15" AnchorPane.rightAnchor="15"/>
                            </AnchorPane>

                            <AnchorPane styleClass="item-card">
                                <VBox spacing="12" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">
                                    <Label text="Antique Travel Compass" styleClass="item-title"/>
                                    <Region styleClass="item-divider"/>
                                    <VBox styleClass="bid-box">
                                        <Label text="CURRENT BID" styleClass="bid-label"/>
                                        <Label text="\$890" styleClass="bid-value"/>
                                    </VBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="45m" styleClass="item-time"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="18 BIDS PLACED" styleClass="item-bids"/>
                                    </HBox>
                                    <Button text="PLACE BID" styleClass="place-bid-btn" maxWidth="Infinity"/>
                                </VBox>
                                <Label text="URGENT" styleClass="stamp, stamp-urgent" AnchorPane.topAnchor="15" AnchorPane.rightAnchor="15"/>
                            </AnchorPane>

                        </FlowPane>
                    </VBox>

                    <Label text="EXPEDITION CATALOG" styleClass="catalog-title-badge" translateY="-18"/>
                </StackPane>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane styleClass="root-pane" stylesheets="@../css/dashboard.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.app.client.controller.DashboardController"
            prefWidth="1280.0" prefHeight="720.0">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
            <padding>
                <Insets top="15" right="35" bottom="15" left="35"/>
            </padding>

            <Label text="tGhauctionRM" styleClass="brand-title"/>

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="welcomeLabel" text="User Name" styleClass="user-name"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="roleLabel" text="BIDDER" styleClass="user-role"/>
                    <Label fx:id="balanceLabel" text="Balance: $0.00" styleClass="user-balance"/>
                </HBox>
            </VBox>

            <Button text="Logout" onAction="#handleLogout" styleClass="action-btn, logout-btn"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Live Auctions" styleClass="section-title"/>
                    <Label text="Browse items and place your bids in real-time." style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Create Auction" onAction="#handleCreateAuction" styleClass="action-btn, create-btn"/>
                    <Button text="Refresh" onAction="#refreshAuctions" styleClass="action-btn, refresh-btn"/>
                </HBox>
            </HBox>

            <Region style="-fx-background-color: transparent; -fx-border-color: #d3dbdc; -fx-border-width: 1 0 0 0; -fx-border-style: solid;"/>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0;" vbarPolicy="AS_NEEDED">
                <VBox fx:id="auctionListContainer" spacing="15">
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
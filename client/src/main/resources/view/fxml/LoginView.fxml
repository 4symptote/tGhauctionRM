<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="root-pane" stylesheets="@../css/global.css, @../css/auth.css"
           fx:controller="com.app.client.controller.LoginController">

    <VBox alignment="CENTER" maxHeight="450.0" maxWidth="400.0" spacing="20.0" styleClass="auth-card">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <Label styleClass="auth-title" text="not enough LoginView" />

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" />

        <VBox spacing="5.0">
            <Label styleClass="input-label" text="Username" />
            <TextField fx:id="usernameField" promptText="Enter username..." styleClass="auth-input" />
        </VBox>

        <VBox spacing="5.0">
            <Label styleClass="input-label" text="Password" />
            <PasswordField fx:id="passwordField" promptText="Enter password..." styleClass="auth-input" />
        </VBox>

        <Region prefHeight="10" />

        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefWidth="Infinity" styleClass="auth-btn" text="Login" />

        <Hyperlink onAction="#switchToRegister" styleClass="auth-link" text="register..." />
    </VBox>
</StackPane>
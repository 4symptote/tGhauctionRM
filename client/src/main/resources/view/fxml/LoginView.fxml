<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.client.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Not Enough Login View">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label fx:id="errorLabel" textFill="RED" wrapText="true" />

    <VBox spacing="5.0">
        <Label text="Username" />
        <TextField fx:id="usernameField" promptText="Enter username..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Password" />
        <PasswordField fx:id="passwordField" promptText="Enter password..." />
    </VBox>

    <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefWidth="Infinity" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px;" text="Login" />

    <Hyperlink onAction="#switchToRegister" text="register" />
</VBox>

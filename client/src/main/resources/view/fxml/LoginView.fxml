<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.client.controller.LoginController">

    <VBox alignment="CENTER" maxHeight="450.0" maxWidth="400.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <Label text="not enought LoginView">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <Label fx:id="errorLabel" textFill="RED" wrapText="true" />

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Username" />
            <TextField fx:id="usernameField" promptText="Enter username..." style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-background-color: #f8f9fa;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Password" />
            <PasswordField fx:id="passwordField" promptText="Enter password..." style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-background-color: #f8f9fa;" />
        </VBox>

        <Region prefHeight="10" />

        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefWidth="Infinity" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px; -fx-background-radius: 4; -fx-cursor: hand;" text="Login" />

        <Hyperlink onAction="#switchToRegister" style="-fx-text-fill: #7f8c8d;" text="register..." />
    </VBox>
</StackPane>
